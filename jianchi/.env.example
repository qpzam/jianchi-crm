# ======================================
# 减持获客系统 - 环境变量配置模板
# ======================================
#
# 使用方法：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 填入你的API密钥
# 3. 确保 .env 文件已添加到 .gitignore
# 4. 运行前加载: source .env 或使用 python-dotenv

# --------------------------------------
# TinyShare/Tushare API
# --------------------------------------
# 用于获取市场数据（股价、PE、质押率等）和历史减持记录
# 获取地址: https://tushare.pro/
TINYSHARE_TOKEN=your_tinyshare_token_here

# --------------------------------------
# AI 解析接口（二选一）
# --------------------------------------
# 方式1: OpenAI 兼容接口
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4

# 方式2: Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
